{
    "name": "tpay/prestashop",
    "description": "Prestashop payment module",
    "license": "OSL-3.0",
    "type": "prestashop-module",
    "authors": [
        {
            "name": "PrestaShop SA",
            "email": "contact@prestashop.com"
        }
    ],
    "require": {
        "php": ">=7.1",
        "ext-json": "*",
        "ext-xml": "*",
        "psr/simple-cache": "^1",
        "tpay-com/tpay-openapi-php": "^2"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.28",
        "friendsofphp/php-cs-fixer": "^3.90",
        "mockery/mockery": "^1.2",
        "phpstan/phpstan": "^2.1",
        "prestashop/autoindex": "^2.1",
        "prestashop/header-stamp": "^3.1",
        "prestashop/php-dev-tools": "^5.0",
        "squizlabs/php_codesniffer": "^4.0",
        "stancer/php-stubs-prestashop": "^8.2",
        "vimeo/psalm": "^4.30"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Tpay\\": "src/"
        },
        "classmap": [
            "tpay.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "prepend-autoloader": false
    },
    "scripts": {
        "build:prod": "composer install -v --no-dev",
        "cs:fixer": "./vendor/bin/php-cs-fixer fix --diff",
        "cs:phpstan": [
            "@putenv _PS_ROOT_DIR_=/var/www/html",
            "./vendor/bin/phpstan --memory-limit=1G --configuration=tests/phpstan/phpstan.neon"
        ],
        "cs:sniffer": "./vendor/bin/phpcs --standard=.phpcs.xml -n",
        "license:update": "./vendor/bin/header-stamp --license=license.txt --exclude=vendor --header-discrimination-string=\"MIT License\"",
        "test": [
            "@putenv XDEBUG_MODE=coverage",
            "@php -d date.timezone=UTC ./vendor/bin/phpunit -c tests/php/phpunit.xml"
        ],
        "test:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit --color=always --coverage-html=\"build\""
        ]
    }
}
